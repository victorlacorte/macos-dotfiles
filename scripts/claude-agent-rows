#!/usr/bin/env bash

# Emit one normalized adapter row per Claude Code agent hosted by a tmux pane.
#
# provider, pane, pid, session kind, state, activity epoch, location, cwd
# Adapted from craftzdog/tmux-claude-session-manager.
# See THIRD_PARTY_NOTICES.md for MIT license attribution.

set -uo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=agent-helpers
. "$DIR/agent-helpers"

claude_cmd="$(get_tmux_option @claude_agent_command 'claude')"
command -v jq >/dev/null 2>&1 || exit 0
command -v "$claude_cmd" >/dev/null 2>&1 || exit 0

agents="$("$claude_cmd" agents --json 2>/dev/null)" || exit 0
rows="$(printf '%s' "$agents" |
  jq -r '.[] | select(.kind == "interactive") | [.pid, .status, .sessionId, .cwd] | @tsv' 2>/dev/null)"
[ -n "$rows" ] || exit 0

mtimes="$(printf '%s\n' "$rows" | cut -f3 | while IFS= read -r sid; do
  printf 'M\t%s\t%s\n' "$sid" "$(claude_transcript_mtime "$sid")"
done)"

{
  ps -Ao pid=,tty= 2>/dev/null | awk '{ print "P\t" $1 "\t" $2 }'
  tmux list-panes -a -F $'T\t#{pane_tty}\t#{pane_id}\t#{session_name}\t#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null
  printf '%s\n' "$mtimes"
  printf '%s\n' "$rows" | sed $'s/^/A\t/'
} | awk -F'\t' -v home="$HOME" \
  -v prefix="$(get_tmux_option @claude_agent_session_prefix 'claude-')" '
  $1 == "P" { tty_of[$2] = $3; next }
  $1 == "T" { sub(/^\/dev\//, "", $2); pane[$2] = $3; sess[$2] = $4; loc[$2] = $5; next }
  $1 == "M" { seen_at[$2] = $3; next }
  $1 == "A" {
    tty = tty_of[$2]
    if (tty == "" || !(tty in pane)) next

    if      ($3 == "waiting") label = "waiting"
    else if ($3 == "idle")    label = "idle"
    else if ($3 == "busy")    label = "working"
    else                       label = "?"
    kind = (index(sess[tty], prefix) == 1) ? "dedicated" : "loose"

    path = $5
    if (path == home || index(path, home "/") == 1)
      path = "~" substr(path, length(home) + 1)

    activity = (seen_at[$4] != "") ? seen_at[$4] : "-"

    printf "claude\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n",
      pane[tty], $2, kind, label, activity, loc[tty], path
  }
'
