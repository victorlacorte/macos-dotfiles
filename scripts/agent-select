#!/usr/bin/env bash

# Interactive fzf selector for Claude Code and Codex tmux panes.

set -uo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=agent-helpers
. "$DIR/agent-helpers"

provider="${AGENT_PICKER_PROVIDER:-all}"
legacy_claude=false
list_only=false
while [ "$#" -gt 0 ]; do
  case "$1" in
  --provider)
    provider="${2:-all}"
    shift 2
    ;;
  --legacy-claude)
    legacy_claude=true
    shift
    ;;
  --list)
    list_only=true
    shift
    ;;
  *)
    shift
    ;;
  esac
done

$list_only && exec "$DIR/agent-rows" --provider "$provider"

for tool in tmux fzf; do
  command -v "$tool" >/dev/null 2>&1 || {
    if command -v tmux >/dev/null 2>&1; then
      tmux display-message "agent-picker: $tool is required"
    else
      printf 'agent-picker: %s is required\n' "$tool" >&2
    fi
    exit 0
  }
done

self="$DIR/agent-select"
export FZF_DEFAULT_OPTS=''
export AGENT_PICKER="$self"
export AGENT_PICKER_PROVIDER="$provider"
# Existing custom @claude_agent_fzf_options values may use this variable.
export CLAUDE_AGENT_PICKER="$self"

extra_opts=()
if $legacy_claude; then
  fzf_options="$(get_tmux_option @claude_agent_fzf_options '')"
else
  fzf_options="$(get_tmux_option_chain '' @agent_fzf_options @claude_agent_fzf_options)"
fi
if [ -n "$fzf_options" ]; then
  # This option intentionally accepts shell-style fzf arguments from tmux.conf.
  eval "extra_opts=($fzf_options)"
fi

header='Agents: enter jump, ctrl-x terminate'
[ "$provider" = claude ] && header='Claude agents: enter jump, ctrl-x terminate'
[ "$provider" = codex ] && header='Codex agents: enter jump, ctrl-x terminate'

sel=$("$DIR/agent-rows" --provider "$provider" |
  fzf --delimiter='\t' --with-nth=2,6,7,8,9 \
    --reverse --cycle --header="$header" \
    --preview='tmux capture-pane -ept {2}' --preview-window='up,70%,follow' \
    --bind='ctrl-x:execute-silent(kill {3})+reload(sleep 0.3; "$AGENT_PICKER" --provider "$AGENT_PICKER_PROVIDER" --list)' \
    ${extra_opts[@]+"${extra_opts[@]}"})

[ -z "$sel" ] && exit 0

pane=$(printf '%s' "$sel" | cut -f2)
kind=$(printf '%s' "$sel" | cut -f4)
selected_provider=$(printf '%s' "$sel" | cut -f5)
if $legacy_claude; then
  parent_option='@claude_agent_parent'
else
  parent_option='@agent_parent'
fi
parent=$(tmux show-options -gqv "$parent_option" 2>/dev/null)
session=$(tmux display-message -p -t "$pane" '#{session_name}' 2>/dev/null)

if [ "$kind" = loose ]; then
  if [ -n "$parent" ]; then
    tmux switch-client -c "$parent" -t "$session" 2>/dev/null
  else
    tmux switch-client -t "$session" 2>/dev/null
  fi
  tmux select-window -t "$pane" 2>/dev/null
  tmux select-pane -t "$pane" 2>/dev/null
  exit 0
fi

origin=$(tmux show-options -qv -t "$session" "@${selected_provider}_agent_origin" 2>/dev/null)
[ -n "$origin" ] || origin=$(tmux show-options -qv -t "$session" @agent_origin 2>/dev/null)
[ -n "$origin" ] && [ -n "$parent" ] &&
  tmux switch-client -c "$parent" -t "$origin" 2>/dev/null

tmux select-window -t "$pane" 2>/dev/null
tmux select-pane -t "$pane" 2>/dev/null
tmux attach-session -t "$session"
