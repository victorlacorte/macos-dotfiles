#!/usr/bin/env bash

# Combine normalized provider rows and prepare the hidden sort/display fields
# consumed by agent-select.

set -uo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
provider='all'
if [ "${1:-}" = '--provider' ]; then
  provider="${2:-all}"
fi

case "$provider" in
all)
  adapters=("$DIR/claude-agent-rows" "$DIR/codex-agent-rows")
  ;;
claude | codex)
  adapters=("$DIR/$provider-agent-rows")
  ;;
*)
  exit 0
  ;;
esac

for adapter in "${adapters[@]}"; do
  [ -x "$adapter" ] && "$adapter"
done | awk -F'\t' -v OFS='\t' -v now="$(date +%s)" '
  NF >= 8 {
    if      ($1 == "claude" && $5 == "waiting") rank = 0
    else if ($1 == "claude" && $5 == "idle")    rank = 1
    else if ($1 == "claude" && $5 == "working") rank = 3
    else                                           rank = 2

    if ($6 ~ /^[0-9]+$/) {
      age_number = int((now - $6) / 60)
      if (age_number < 0) age_number = 0
      age = age_number "m"
    } else {
      age_number = 0
      age = "-"
    }

    # rank and numeric age are hidden; the visible fields are provider, state,
    # age, tmux location, and path.
    print rank, $2, $3, $4, $1, $5, sprintf("%5s", age), $7, $8, age_number
  }
' | LC_ALL=C sort -t$'\t' -k1,1n -k10,10n -k2,2 -k8,8
