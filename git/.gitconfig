[gpg]
	program = gpg
[commit]
	gpgsign = true
[user]
	email = 1683634+victorlacorte@users.noreply.github.com
	name = Victor Lacorte
[core]
	editor = nvim
	ignorecase = false
[fetch]
	prune = true
[rerere]
	enabled = true
[rebase]
	autoSquash = true
[push]
	useForceIfIncludes = true
	recurseSubmodules = on-demand
[init]
	defaultBranch = main
[status]
	submoduleSummary = 1
[alias]
	branchsort = !git branch --sort=-committerdate --format='%(refname:short) %(committerdate:relative)'
	fixup = !git commit --fixup=$(git log --oneline -n 30 | fzf | cut -d\" \" -f1)
[include]
	path = .gitconfig.local
